---
import FrameLayout from "@layouts/FrameLayout.astro";
import { Reveal } from "@components/ui/Reveal";
import { Dot } from "@components/ui/Dot";
---

<FrameLayout
  title="404 – Seite nicht gefunden"
  description="Die gesuchte Seite existiert nicht oder wurde verschoben."
>
  <section
    class="pt-32 sm:pt-40 pb-16 sm:pb-20 px-6 sm:px-10 md:px-16 lg:px-20 min-h-[70vh] flex items-center"
  >
    <div
      class="grid grid-cols-1 md:grid-cols-[minmax(100px,240px)_1fr] gap-6 md:gap-12 lg:gap-15 items-start w-full"
    >
      <!-- Left Label -->
      <Reveal client:load>
        <div class="md:sticky md:top-[98px]">
          <p
            class="text-xs sm:text-sm font-medium text-dark/40 tracking-[0.08em] uppercase"
          >
            Fehler 404
          </p>
        </div>
      </Reveal>

      <!-- Right Content -->
      <div class="max-w-full md:max-w-[680px]">
        <Reveal client:load>
          <p
            class="text-[120px] sm:text-[160px] md:text-[200px] font-black leading-[0.85] tracking-[-0.04em] text-dark/[0.06] select-none mb-6"
          >
            404
          </p>
        </Reveal>

        <Reveal client:load delay={0.06}>
          <h1
            class="text-3xl sm:text-4xl md:text-[clamp(34px,4.5vw,60px)] font-black leading-[0.95] tracking-[-0.025em] mb-5 md:mb-7"
          >
            Hier ist nichts<Dot />
          </h1>
        </Reveal>

        <Reveal client:load delay={0.1}>
          <p
            class="text-xl sm:text-2xl md:text-[clamp(22px,2.8vw,34px)] font-serif leading-[1.45] mb-5 md:mb-7"
          >
            Die Seite, die du suchst, gibt es nicht mehr — oder sie war nie
            hier.
          </p>
        </Reveal>

        <Reveal client:load delay={0.14}>
          <p
            class="text-base sm:text-lg font-light leading-[1.75] text-[#525252] mb-10"
          >
            Falls du über einen älteren Link hierher gekommen bist: Ich habe
            meine Website neu aufgebaut. Einige Inhalte sind umgezogen oder neu
            sortiert. Schau gerne im Blog oder auf der Startseite vorbei.
          </p>
        </Reveal>

        <Reveal client:load delay={0.18}>
          <div class="flex flex-wrap gap-4">
            <a
              href="/"
              class="inline-block bg-dark text-white px-7 py-3.5 text-sm font-medium tracking-wide transition-colors duration-300 hover:bg-accent"
            >
              Zur Startseite
            </a>
            <a
              href="/blog"
              class="inline-block border border-dark/20 text-dark px-7 py-3.5 text-sm font-medium tracking-wide transition-all duration-300 hover:border-dark/60 hover:bg-dark hover:text-white"
            >
              Zum Blog
            </a>
          </div>
        </Reveal>
      </div>
    </div>
  </section>
</FrameLayout>
