---
import Base from "@/layouts/Base.astro";
---

<Base title="404 - Seite nicht gefunden" description="Fehlerseite">
  <div class="flex flex-col items-center justify-center py-24 text-center">
    <h1 class="text-9xl font-black text-gray-200">404</h1>
    <h2 class="text-3xl font-bold mt-4">Seite nicht gefunden</h2>
    <p class="text-gray-600 mt-4 max-w-md">
      Die gesuchte Seite existiert leider nicht. Vielleicht wurde sie verschoben
      oder gelöscht.
    </p>
    <a
      href="/"
      class="mt-8 bg-gray-900 text-white px-6 py-3 rounded-lg font-medium hover:bg-gray-800 transition-colors"
    >
      Zur Startseite
    </a>
  </div>
</Base>
