---
import Base from "@/layouts/Base.astro";
---

<Base title="Impressum" description="Impressum">
  <div class="prose prose-lg mx-auto py-12">
    <h1>Impressum</h1>

    <h2>Angaben gemäß § 5 TMG</h2>
    <p>
      [Dein Name / Firmenname]<br />
      [Straße Hausnummer]<br />
      [PLZ Ort]
    </p>

    <h2>Kontakt</h2>
    <p>
      E-Mail: [Deine E-Mail]<br />
      Telefon: [Deine Telefonnummer] (optional)
    </p>

    <h2>Redaktionell verantwortlich</h2>
    <p>
      [Dein Name]<br />
      [Straße Hausnummer]<br />
      [PLZ Ort]
    </p>
  </div>
</Base>
