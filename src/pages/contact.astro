---
import FrameLayout from "@layouts/FrameLayout.astro";
import ContactForm from "@components/ContactForm";
import Newsletter from "@components/sections/Newsletter.astro";
import { Reveal } from "@components/ui/Reveal";
import { Dot } from "@components/ui/Dot";
---

<FrameLayout
  title="Kontakt – Rico Loschke"
  description="Schreib mir. Ob Frage, Idee oder Zusammenarbeit – ich freue mich auf deine Nachricht."
>
  <!-- Hero -->
  <section
    class="pt-32 sm:pt-40 pb-16 sm:pb-20 px-6 sm:px-10 md:px-16 lg:px-20"
  >
    <div
      class="grid grid-cols-1 md:grid-cols-[minmax(100px,240px)_1fr] gap-6 md:gap-12 lg:gap-15 items-start"
    >
      <!-- Left Label -->
      <Reveal client:load>
        <div class="md:sticky md:top-[98px]">
          <p
            class="text-xs sm:text-sm font-medium text-dark/40 tracking-[0.08em] uppercase"
          >
            Austausch
          </p>
        </div>
      </Reveal>

      <!-- Right Content -->
      <div class="max-w-full md:max-w-[680px]">
        <Reveal client:load>
          <h1
            class="text-3xl sm:text-4xl md:text-[clamp(34px,4.5vw,60px)] font-black leading-[0.95] tracking-[-0.025em] mb-5 md:mb-7"
          >
            Lass uns reden<Dot />
          </h1>
        </Reveal>

        <Reveal client:load delay={0.08}>
          <p
            class="text-xl sm:text-2xl md:text-[clamp(22px,2.8vw,34px)] font-serif leading-[1.45] mb-5 md:mb-7"
          >
            Du hast eine Frage, eine Idee oder willst einfach Hallo sagen? Kein
            Anliegen ist zu klein. Ich antworte persönlich.
          </p>
        </Reveal>

        <Reveal client:load delay={0.12}>
          <p
            class="text-base sm:text-lg font-light leading-[1.75] text-[#525252] mb-10"
          >
            Am liebsten über das Formular unten. Oder finde mich auf einer der
            Plattformen.
          </p>
        </Reveal>

        <Reveal client:load delay={0.16}>
          <div class="flex flex-wrap gap-4 items-center">
            <!-- LinkedIn -->
            <a
              href="https://www.linkedin.com/in/rico-loschke/"
              target="_blank"
              rel="noopener"
              class="group flex items-center gap-2.5 px-4 py-2.5 border border-dark/15 hover:border-dark/40 hover:bg-dark hover:text-white text-dark/70 transition-all duration-300"
            >
              <svg
                width="18"
                height="18"
                viewBox="0 0 24 24"
                fill="currentColor"
              >
                <path
                  d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433c-1.144 0-2.063-.926-2.063-2.065 0-1.138.92-2.063 2.063-2.063 1.14 0 2.064.925 2.064 2.063 0 1.139-.925 2.065-2.064 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"
                ></path>
              </svg>
              <span class="text-sm font-medium">LinkedIn</span>
            </a>
            <!-- YouTube -->
            <a
              href="https://www.youtube.com/@LoschkeAI"
              target="_blank"
              rel="noopener"
              class="group flex items-center gap-2.5 px-4 py-2.5 border border-dark/15 hover:border-dark/40 hover:bg-dark hover:text-white text-dark/70 transition-all duration-300"
            >
              <svg
                width="18"
                height="18"
                viewBox="0 0 24 24"
                fill="currentColor"
              >
                <path
                  d="M23.498 6.186a3.016 3.016 0 0 0-2.122-2.136C19.505 3.545 12 3.545 12 3.545s-7.505 0-9.377.505A3.017 3.017 0 0 0 .502 6.186C0 8.07 0 12 0 12s0 3.93.502 5.814a3.016 3.016 0 0 0 2.122 2.136c1.871.505 9.376.505 9.376.505s7.505 0 9.377-.505a3.015 3.015 0 0 0 2.122-2.136C24 15.93 24 12 24 12s0-3.93-.502-5.814zM9.545 15.568V8.432L15.818 12l-6.273 3.568z"
                ></path>
              </svg>
              <span class="text-sm font-medium">YouTube</span>
            </a>
            <!-- Instagram -->
            <a
              href="https://www.instagram.com/loschkeai/"
              target="_blank"
              rel="noopener"
              class="group flex items-center gap-2.5 px-4 py-2.5 border border-dark/15 hover:border-dark/40 hover:bg-dark hover:text-white text-dark/70 transition-all duration-300"
            >
              <svg
                width="18"
                height="18"
                viewBox="0 0 24 24"
                fill="currentColor"
              >
                <path
                  d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zM12 0C8.741 0 8.333.014 7.053.072 2.695.272.273 2.69.073 7.052.014 8.333 0 8.741 0 12c0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98C8.333 23.986 8.741 24 12 24c3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98C15.668.014 15.259 0 12 0zm0 5.838a6.162 6.162 0 1 0 0 12.324 6.162 6.162 0 0 0 0-12.324zM12 16a4 4 0 1 1 0-8 4 4 0 0 1 0 8zm6.406-11.845a1.44 1.44 0 1 0 0 2.881 1.44 1.44 0 0 0 0-2.881z"
                ></path>
              </svg>
              <span class="text-sm font-medium">Instagram</span>
            </a>
          </div>
        </Reveal>
      </div>
    </div>
  </section>

  <!-- Kontaktformular -->
  <section
    class="py-16 md:py-24 lg:py-[100px] px-6 sm:px-10 md:px-16 lg:px-20 border-t border-[#e5e5e5]"
  >
    <div
      class="grid grid-cols-1 md:grid-cols-[minmax(100px,240px)_1fr] gap-6 md:gap-12 lg:gap-15 items-start"
    >
      <!-- Left Label -->
      <Reveal client:load>
        <div class="md:sticky md:top-[98px]">
          <p
            class="text-xs sm:text-sm font-medium text-dark/40 tracking-[0.08em] uppercase mb-4"
          >
            Nachricht
          </p>
          <p
            class="text-sm font-light leading-[1.6] text-dark/40 max-w-[180px] hidden md:block"
          >
            Drei Felder, keine Pflichtangaben außer den Basics.
          </p>
        </div>
      </Reveal>

      <!-- Right Content -->
      <div class="max-w-full md:max-w-[560px]">
        <ContactForm client:load />
      </div>
    </div>
  </section>

  <!-- Newsletter -->
  <Newsletter
    headline="Lieber erstmal mitlesen?"
    text="Neue Artikel und Gedanken zu KI direkt ins Postfach. Kein Spam, kein Tracking. Etwa 2× im Monat."
    label="Newsletter"
  />
</FrameLayout>
