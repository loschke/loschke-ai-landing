---
import FrameLayout from "@layouts/FrameLayout.astro";
import { HeroLine } from "@components/ui/HeroLine";
import { Dot } from "@components/ui/Dot";
import ContentSection from "@components/sections/arbeit/ContentSection.astro";
import {
  FrameworkTabs,
  type PromptToken,
} from "@components/sections/arbeit/FrameworkTabs";
import { PromptExample } from "@components/sections/arbeit/PromptExample";
import CTA from "@components/sections/CTA.astro";

// Helper, damit die Token-Arrays unten kompakt bleiben
