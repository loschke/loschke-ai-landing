---
import FrameLayout from "@layouts/FrameLayout.astro";
import Hero from "@components/sections/speaking/Hero.astro";
import Credentials from "@components/sections/speaking/Credentials.astro";
import About from "@components/sections/speaking/About.astro";
import Topics from "@components/sections/speaking/Topics.astro";
import Approach from "@components/sections/speaking/Approach.astro";
import CTA from "@components/sections/CTA.astro";
---

<FrameLayout
  title="Speaking – Keynotes & Impulsvorträge"
  description="Keynotes und Impulsvorträge zu KI und Transformation. Perspektiven statt Versprechen. Erfahrung aus der Praxis statt Folien aus dem Internet."
>
  <Hero />
  <Credentials />
  <About />
  <Topics />
  <Approach />
  <CTA
    headline="Passt ein Thema\nzu deiner Veranstaltung"
    text="Schreib mir, was du vorhast. Ich melde mich innerhalb von zwei Tagen mit einer ehrlichen Einschätzung, ob und wie ich helfen kann."
  />
</FrameLayout>
