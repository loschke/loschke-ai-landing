---
import FrameLayout from "@layouts/FrameLayout.astro";
import Hero from "@components/sections/blog/Hero.astro";
import { BlogContent } from "@components/sections/blog/BlogContent";
import Newsletter from "@components/sections/Newsletter.astro";
import CTA from "@components/sections/CTA.astro";
import { getCollection } from "astro:content";
import { categoryMeta, type Category } from "@content/config";

// Fetch and prepare posts
const posts = (await getCollection("posts"))
  .filter((post) => !post.data.draft)
  .sort((a, b) => {
    const dateA = a.data.pubDate?.valueOf() || 0;
    const dateB = b.data.pubDate?.valueOf() || 0;
    return dateB - dateA;
  });

// Transform posts into the shape BlogContent expects
const articles = posts.map((post) => {
  const cat = post.data.category as Category;
  const meta = categoryMeta[cat] || categoryMeta.takes;

  return {
    slug: post.slug,
    title: post.data.title,
    excerpt: post.data.excerpt || post.data.metaDescription || undefined,
    category: cat,
    categoryLabel: meta.label,
    categoryIcon: meta.icon,
    readTime: post.data.readTime || undefined,
    featured: post.data.featured,
    tags: post.data.tags || [],
    hasAudio: !!post.data.audioSrc,
  };
});
---

<FrameLayout
  title="Blog – Gedanken & Experimente"
  description="Über KI, Arbeit und was sich verändert. Beobachtungen, Experimente, Einordnungen."
>
  <Hero />
  <BlogContent client:load articles={articles} />
  <Newsletter />
  <CTA
    headline="Lass uns\naustauschen"
    text="Du hast Gedanken zu einem Artikel oder eine Frage? Schreib mir — ich freue mich über den Dialog."
  />
</FrameLayout>
