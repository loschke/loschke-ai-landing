---
import { getCollection } from "astro:content";
import FrameLayout from "@layouts/FrameLayout.astro";
import { categoryMeta, type Category } from "@content/config";
import ArticleHeader from "@components/sections/blog/ArticleHeader.astro";
import ArticleBody from "@components/sections/blog/ArticleBody.astro";

export async function getStaticPaths() {
  const posts = await getCollection("posts");
  return posts.map((post) => ({
    params: { slug: post.slug },
    props: post,
  }));
}

const post = Astro.props;
const { Content, headings } = await post.render();

const cat = post.data.category as Category;
const meta = categoryMeta[cat] || categoryMeta.takes;

// SEO: Use metaTitle/metaDescription if set, otherwise fallback
const seoTitle = post.data.metaTitle || post.data.title;
const seoDescription = post.data.metaDescription || post.data.excerpt || "";
---

<FrameLayout
  title={seoTitle}
  description={seoDescription}
  image={post.data.ogImage || "/og-default-blog.png"}
  article
>
  <ArticleHeader
    title={post.data.title}
    excerpt={post.data.excerpt}
    category={meta.label}
    categoryIcon={meta.icon}
    readTime={post.data.readTime}
    tags={post.data.tags}
    pubDate={post.data.pubDate}
  />
  <ArticleBody
    summary={post.data.summary}
    audioSrc={post.data.audioSrc}
    headings={headings}
    slug={post.slug}
  >
    <Content />
  </ArticleBody>
</FrameLayout>
