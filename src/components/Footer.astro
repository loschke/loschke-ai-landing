---
const year = new Date().getFullYear();

const legalLinks = [
  { label: "Impressum", href: "/impressum" },
  { label: "Datenschutz", href: "/datenschutz" },
  { label: "llms.txt", href: "/llms.txt" },
];

const ecosystemLinks = [
  { label: "unlearn.how", href: "https://unlearn.how", external: true },
  { label: "lernen.diy", href: "https://lernen.diy", external: true },
];

const socialLinks = [
  { label: "LinkedIn", href: "https://linkedin.com/in/loschke" },
  { label: "Instagram", href: "https://instagram.com/loschke" },
  { label: "YouTube", href: "https://youtube.com/@loschke" },
];
---

<footer class="bg-accent text-white pt-16 pb-8 px-6 sm:px-10 md:px-16 lg:px-20">
  <div
    class="grid grid-cols-1 md:grid-cols-[1fr_auto_auto_auto] gap-12 md:gap-16 mb-16"
  >
    <!-- Brand -->
    <div class="max-w-[320px]">
      <a href="/" class="inline-block mb-4">
        <span class="text-xl sm:text-2xl font-black tracking-[-0.02em] text-white">
          RL<span class="text-dark">.</span>
        </span>
      </a>
      <p class="text-base sm:text-lg font-light leading-[1.75] text-white/80 mb-4">
        Rico Loschke — 
        AI Transformation mit 
        Prinzipien statt Tricks.
      </p>
      <p class="text-xs sm:text-sm text-white/60">
        In Dresden zuhause, im DACH-Raum verfügbar.
      </p>
    </div>

    <!-- Ökosystem -->
    <div>
      <h4
        class="text-xs sm:text-sm font-medium text-white/60 tracking-[0.08em] uppercase mb-4"
      >
        Ökosystem
      </h4>
      <ul class="space-y-3">
        {
          ecosystemLinks.map((link) => (
            <li>
              <a
                href={link.href}
                target={link.external ? "_blank" : undefined}
                rel={link.external ? "noopener" : undefined}
                class="text-sm sm:text-base text-white/80 hover:text-white transition-colors duration-200"
              >
                {link.label}
              </a>
            </li>
          ))
        }
      </ul>
    </div>

    <!-- Social -->
    <div>
      <h4
        class="text-xs sm:text-sm font-medium text-white/60 tracking-[0.08em] uppercase mb-4"
      >
        Social
      </h4>
      <ul class="space-y-3">
        {
          socialLinks.map((link) => (
            <li>
              <a
                href={link.href}
                target="_blank"
                rel="noopener"
                class="text-sm sm:text-base text-white/80 hover:text-white transition-colors duration-200"
              >
                {link.label}
              </a>
            </li>
          ))
        }
      </ul>
    </div>

    <!-- Legal -->
    <div>
      <h4
        class="text-xs sm:text-sm font-medium text-white/60 tracking-[0.08em] uppercase mb-4"
      >
        Legal
      </h4>
      <ul class="space-y-3">
        {
          legalLinks.map((link) => (
            <li>
              <a
                href={link.href}
                class="text-sm sm:text-base text-white/80 hover:text-white transition-colors duration-200"
              >
                {link.label}
              </a>
            </li>
          ))
        }
      </ul>
    </div>
  </div>

  <!-- Copyright -->
  <div
    class="pt-8 border-t border-white/20 flex flex-col sm:flex-row justify-between items-center gap-4"
  >
    <span class="text-xs sm:text-sm text-white/60">© {year} Rico Loschke</span>
    <span class="text-xs sm:text-sm text-white/40">Built with Astro & Claude</span>
  </div>
</footer>
