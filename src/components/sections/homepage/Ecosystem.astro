---
import { Reveal } from "@components/ui/Reveal";
import { Dot } from "@components/ui/Dot";
---

<section
  class="py-16 md:py-24 lg:py-[100px] px-6 sm:px-10 md:px-16 lg:px-20 border-t border-[#e5e5e5]"
>
  <div
    class="grid grid-cols-1 md:grid-cols-[minmax(100px,240px)_1fr] gap-6 md:gap-12 lg:gap-15 items-start"
  >
    <Reveal client:load>
      <p
        class="text-xs sm:text-sm font-medium text-[#737373] tracking-[0.08em] uppercase md:sticky md:top-[98px]"
      >
        Ökosystem
      </p>
    </Reveal>

    <div>
      <Reveal client:load>
        <p
          class="text-xl sm:text-2xl md:text-[clamp(22px,2.8vw,34px)] font-serif leading-[1.45] mb-10 md:mb-12 max-w-full md:max-w-[560px]"
        >
          Drei Plattformen, ein Ziel: Menschen und Organisationen fit machen für
          die KI-Ära.
        </p>
      </Reveal>

      <div class="grid grid-cols-1 sm:grid-cols-3 gap-8 sm:gap-10">
        <!-- loschke.ai -->
        <Reveal client:load delay={0}>
          <div class="pt-6 border-t-2 border-accent">
            <div class="mb-3">
              <span class="text-xl sm:text-2xl font-black tracking-[-0.02em]">
                RL<span class="text-accent">.</span>
              </span>
            </div>
            <p class="text-xs sm:text-sm font-medium text-accent mb-2">
              Du bist hier
            </p>
            <p
              class="text-base sm:text-lg font-light leading-[1.75] text-[#525252]"
            >
              Denken, Experimente, Meinung. Was ich über KI lerne und baue.
            </p>
          </div>
        </Reveal>

        <!-- unlearn.how -->
        <Reveal client:load delay={0.1}>
          <a
            href="https://unlearn.how"
            target="_blank"
            rel="noopener"
            class="block pt-6 border-t border-[#e5e5e5] group"
          >
            <div class="mb-3">
              <span class="text-xl sm:text-2xl tracking-[-0.01em]">
                <span class="font-serif italic">unlearn</span><span
                  class="font-serif text-[#a855f7]">.how</span
                >
              </span>
            </div>
            <p class="text-xs sm:text-sm font-medium text-[#737373] mb-2">
              Für Organisationen
            </p>
            <p
              class="text-base sm:text-lg font-light leading-[1.75] text-[#525252] mb-3"
            >
              Beratung und Workshops für Führungskräfte und Teams.
            </p>
            <span
              class="text-sm sm:text-base font-medium text-[#a855f7] group-hover:underline"
            >
              Zur Website →
            </span>
          </a>
        </Reveal>

        <!-- lernen.diy -->
        <Reveal client:load delay={0.2}>
          <a
            href="https://lernen.diy"
            target="_blank"
            rel="noopener"
            class="block pt-6 border-t border-[#e5e5e5] group"
          >
            <div class="mb-3">
              <span class="text-xl sm:text-2xl tracking-[-0.01em]">
                <span class="font-serif">lernen</span><span
                  class="font-serif italic text-[#0F766E]">.diy</span
                >
              </span>
            </div>
            <p class="text-xs sm:text-sm font-medium text-[#737373] mb-2">
              Für alle
            </p>
            <p
              class="text-base sm:text-lg font-light leading-[1.75] text-[#525252] mb-3"
            >
              Guides, Labs, Ressourcen. Lerne KI im eigenen Tempo.
            </p>
            <span
              class="text-sm sm:text-base font-medium text-[#0F766E] group-hover:underline"
            >
              Benachrichtigung erhalten →
            </span>
          </a>
        </Reveal>
      </div>
    </div>
  </div>
</section>
