---
import { Reveal } from "@components/ui/Reveal";
import { Dot } from "@components/ui/Dot";
---

<section
  class="py-16 md:py-24 lg:py-[100px] px-6 sm:px-10 md:px-16 lg:px-20 bg-[#fafafa]"
>
  <div
    class="grid grid-cols-1 md:grid-cols-[minmax(100px,240px)_1fr] gap-6 md:gap-12 lg:gap-15 items-start"
  >
    <Reveal client:load>
      <div class="md:sticky md:top-[98px]">
        <p
          class="text-xs sm:text-sm font-medium text-[#737373] tracking-[0.08em] uppercase mb-4"
        >
          Manifest
        </p>
        <p
          class="text-sm font-light leading-[1.6] text-[#737373] max-w-[180px] hidden md:block"
        >
          Wofür ich stehe. Wie ich arbeite. Was ich glaube.
        </p>
      </div>
    </Reveal>

    <div class="max-w-[680px]">
      <Reveal client:load>
        <h2
          class="text-3xl sm:text-4xl md:text-[clamp(34px,4.5vw,60px)] font-black leading-[0.95] tracking-[-0.025em] mb-5 md:mb-7"
        >
          7 Grundsätze<Dot />
        </h2>
      </Reveal>

      <Reveal client:load delay={0.08}>
        <p
          class="text-xl sm:text-2xl md:text-[clamp(22px,2.8vw,34px)] font-serif leading-[1.45] mb-6 md:mb-8"
        >
          Jeden Tag ein neues KI-Tool. Jeden Tag neue Schlagzeilen. Ich glaube,
          es geht anders — nicht mit mehr Hype, sondern mit klarem Denken.
        </p>
      </Reveal>

      <Reveal client:load delay={0.16}>
        <a
          href="/manifest"
          class="inline-block text-sm sm:text-base font-medium text-accent border-b border-transparent hover:border-accent transition-colors duration-250"
        >
          Zum Manifest →
        </a>
      </Reveal>
    </div>
  </div>
</section>
