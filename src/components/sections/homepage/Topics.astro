---
import { Reveal } from "@components/ui/Reveal";
import { Dot } from "@components/ui/Dot";

const pillars = [
  { label: "Visionen & Prognosen", sub: "Was kommt auf uns zu" },
  { label: "Takes & Meinungen", sub: "Was ich denke" },
  { label: "Experimente & Learnings", sub: "Ich hab's ausprobiert" },
  { label: "Building in Public", sub: "Die Reise zeigen" },
  { label: "Persönliches", sub: "Was ich auf dem Weg lerne" },
];
---

<section
  class="py-16 md:py-24 lg:py-[100px] px-6 sm:px-10 md:px-16 lg:px-20 border-t border-[#e5e5e5]"
>
  <div
    class="grid grid-cols-1 md:grid-cols-[minmax(100px,240px)_1fr] gap-6 md:gap-12 lg:gap-15 items-start"
  >
    <Reveal client:load>
      <p
        class="text-xs sm:text-sm font-medium text-[#737373] tracking-[0.08em] uppercase md:sticky md:top-[98px]"
      >
        Themen
      </p>
    </Reveal>

    <div>
      <Reveal client:load>
        <h2
          class="text-3xl sm:text-4xl md:text-[clamp(34px,4.5vw,60px)] font-black leading-[0.95] tracking-[-0.025em] mb-10 md:mb-14"
        >
          Worüber ich<br />nachdenke<Dot />
        </h2>
      </Reveal>

      <div
        class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 xl:grid-cols-5 gap-0"
      >
        {
          pillars.map((pillar, i) => (
            <Reveal client:load delay={i * 0.08}>
              <div class="py-6 sm:py-7 pr-5 border-t border-[#e5e5e5]">
                <span
                  class="w-2 h-2 bg-accent rounded-full block mb-3"
                  aria-hidden="true"
                />
                <h3 class="text-base sm:text-lg font-black tracking-[-0.01em] mb-1">
                  {pillar.label}
                </h3>
                <p class="text-base sm:text-lg font-light text-[#525252] leading-[1.75]">
                  {pillar.sub}
                </p>
              </div>
            </Reveal>
          ))
        }
      </div>
    </div>
  </div>
</section>
