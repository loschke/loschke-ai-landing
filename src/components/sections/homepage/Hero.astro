---
import { HeroLine } from "@components/ui/HeroLine";
import { Reveal } from "@components/ui/Reveal";
import { Dot } from "@components/ui/Dot";
import { AvatarIntro } from "@components/ui/AvatarIntro";

// Note: Time calculation would need a client component or script.
// For now, hardcoded or omitted to keep it simple.
---

<section
  class="min-h-[calc(100vh-36px)] flex flex-col justify-center px-6 sm:px-10 md:px-16 lg:px-20"
>
  <div class="max-w-none">
    <HeroLine client:load delay={0.15}>
      <div class="flex items-center gap-4 mb-6 sm:mb-8 md:mb-10">
        <p
          class="text-xs sm:text-sm font-medium text-[#737373] tracking-[0.08em] uppercase"
        >
          Rico Loschke · AI · Visionen · Konzepte · Skills
        </p>
      </div>
    </HeroLine>

    <h1
      class="text-5xl sm:text-6xl md:text-[clamp(80px,11vw,180px)] font-sans font-black leading-[0.88] tracking-[-0.04em] mb-8 sm:mb-10 text-dark"
    >
      <HeroLine client:load delay={0.25}>Prinzipien</HeroLine>
      <HeroLine client:load delay={0.38}>
        statt Tricks<Dot />
      </HeroLine>
    </h1>

    <div class="max-w-full sm:max-w-[600px] md:max-w-[800px] mb-8 sm:mb-10">
      <HeroLine client:load delay={0.6}>
        <p
          class="text-xl sm:text-2xl md:text-[clamp(24px,3vw,36px)] font-serif font-normal leading-[1.4] sm:leading-[1.35] text-[#525252]"
        >
          Ich denke über KI nach. Keine Hacks, keine Marketing-Versprechen —
          sondern klares Denken, ehrliche Einschätzungen und was ich auf dem Weg
          lerne.
        </p>
      </HeroLine>
    </div>

    <div>
      <HeroLine client:load delay={0.75}>
        <div
          class="flex flex-col sm:flex-row gap-4 sm:gap-8 items-start sm:items-center"
        >
          <a
            href="/blog"
            class="inline-block bg-dark text-white px-6 sm:px-8 py-3 sm:py-4 text-sm sm:text-base font-medium tracking-[0.02em] hover:bg-accent transition-colors duration-300"
          >
            Blog lesen
          </a>
          <a
            href="/manifest"
            class="inline-block py-3 sm:py-4 text-sm sm:text-base font-medium text-accent border-b border-transparent hover:border-accent transition-colors duration-250"
          >
            Mein Manifest →
          </a>
        </div>
      </HeroLine>
    </div>
  </div>
</section>
