---
import { Reveal } from "@components/ui/Reveal";

const credentials = ["IHK", "Haufe Akademie", "Fraunhofer", "AOK", "MVFP Akademie"];
---

<section class="py-12 md:py-16 px-6 sm:px-10 md:px-16 lg:px-20 bg-dark">
  <div
    class="grid grid-cols-1 md:grid-cols-[minmax(100px,240px)_1fr] gap-6 md:gap-12 lg:gap-15 items-start"
  >
    <!-- Left Label -->
    <Reveal client:load>
      <p
        class="text-xs sm:text-sm font-medium text-white/50 tracking-[0.08em] uppercase"
      >
        Vertrauen
      </p>
    </Reveal>

    <!-- Right Content -->
    <div>
      <Reveal client:load>
        <p class="text-sm text-white/60 mb-3">
          Diese Organisationen vertrauen auf meine Expertise und Trainings:
        </p>
      </Reveal>
      <Reveal client:load delay={0.08}>
        <p
          class="text-xl sm:text-2xl md:text-3xl font-black text-white tracking-[-0.02em]"
        >
          {credentials.join("  ·  ")}
        </p>
      </Reveal>
    </div>
  </div>
</section>
