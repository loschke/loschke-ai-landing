---
import { Reveal } from "@components/ui/Reveal";
import { Dot } from "@components/ui/Dot";
---

<section
  class="py-16 md:py-24 lg:py-[100px] px-6 sm:px-10 md:px-16 lg:px-20 border-t border-[#e5e5e5] bg-[#fafafa]"
>
  <div
    class="grid grid-cols-1 md:grid-cols-[minmax(100px,240px)_1fr] gap-6 md:gap-12 lg:gap-15 items-start"
  >
    <Reveal client:load>
      <p
        class="text-xs sm:text-sm font-medium text-[#737373] tracking-[0.08em] uppercase"
      >
        Newsletter
      </p>
    </Reveal>

    <div class="max-w-full md:max-w-[560px]">
      <Reveal client:load>
        <h2
          class="text-3xl sm:text-4xl md:text-[clamp(28px,4vw,44px)] font-black leading-[0.95] tracking-[-0.02em] mb-5"
        >
          Nichts verpassen<Dot />
        </h2>
      </Reveal>

      <Reveal client:load delay={0.1}>
        <p class="text-base font-light leading-[1.6] text-[#525252] mb-7">
          Neue Artikel direkt ins Postfach. Kein Spam, keine Werbung. Etwa 2× im
          Monat.
        </p>
      </Reveal>

      <Reveal client:load delay={0.15}>
        <form class="flex gap-3 flex-wrap">
          <input
            type="email"
            placeholder="E-Mail-Adresse"
            class="flex-[1_1_240px] px-4 py-3.5 text-sm border border-[#e5e5e5] bg-white font-sans outline-none focus:border-dark transition-colors duration-250"
          />
          <button
            type="submit"
            class="px-7 py-3.5 bg-dark text-white text-[13px] font-medium border-none cursor-pointer font-sans transition-colors duration-300 hover:bg-accent"
          >
            Abonnieren
          </button>
        </form>
      </Reveal>
    </div>
  </div>
</section>
