---
import { Reveal } from "@components/ui/Reveal";
import { Dot } from "@components/ui/Dot";
import { TableOfContents } from "@components/sections/blog/TableOfContents";
import { SummaryAudioBox } from "@components/sections/blog/SummaryAudioBox";

interface Props {
  summary?: string;
  audioSrc?: string;
  headings: { depth: number; slug: string; text: string }[];
  slug: string;
}

const { summary, audioSrc, headings, slug } = Astro.props;

// Filter headings for TOC (h2 and h3 only)
const tocItems = headings
  .filter((h) => h.depth === 2 || h.depth === 3)
  .map((h) => ({
    id: h.slug,
    label: h.text,
    level: h.depth === 3 ? 2 : 1,
  }));

const hasSummaryOrAudio = summary || audioSrc;
const hasToc = tocItems.length > 0;
---

<article
  class="py-16 md:py-24 lg:py-[100px] px-6 sm:px-10 md:px-16 lg:px-20 border-t border-[#e5e5e5]"
>
  <div
    class="grid grid-cols-1 md:grid-cols-[minmax(100px,240px)_1fr] gap-6 md:gap-12 lg:gap-15 items-start"
  >
    <!-- Left Sidebar: TOC + Share (sticky, hidden on mobile) -->
    <div class="hidden md:block md:sticky md:top-[98px]">
      {
        hasToc && (
          <Reveal client:load>
            <TableOfContents client:load items={tocItems} />
          </Reveal>
        )
      }

      {/* Share Links */}
      <Reveal client:load delay={0.1}>
        <div class:list={[hasToc ? "mt-8 pt-6 border-t border-[#e5e5e5]" : ""]}>
          <p
            class="text-[11px] font-medium text-[#a3a3a3] tracking-[0.1em] uppercase mb-3"
          >
            Teilen
          </p>
          <div class="flex gap-4">
            <a
              href={`https://www.linkedin.com/sharing/share-offsite/?url=https://loschke.ai/blog/${slug}`}
              target="_blank"
              rel="noopener noreferrer"
              class="text-xs font-medium text-[#737373] hover:text-accent transition-colors duration-200"
            >
              LinkedIn
            </a>
            <a
              href={`https://twitter.com/intent/tweet?url=https://loschke.ai/blog/${slug}`}
              target="_blank"
              rel="noopener noreferrer"
              class="text-xs font-medium text-[#737373] hover:text-accent transition-colors duration-200"
            >
              Twitter
            </a>
          </div>
        </div>
      </Reveal>
    </div>

    <!-- Right: Article Content -->
    <div class="max-w-full md:max-w-[900px]">
      <!-- Summary + Audio Box (Variante B1) -->
      {
        hasSummaryOrAudio && (
          <Reveal client:load>
            <SummaryAudioBox
              client:load
              summary={summary}
              audioSrc={audioSrc}
            />
          </Reveal>
        )
      }

      <!-- Prose Content -->
      <Reveal client:load delay={0.1}>
        <div
          class:list={[
            "prose prose-lg max-w-none",
            // Headings
            "prose-headings:font-sans prose-headings:font-black prose-headings:tracking-[-0.02em]",
            "prose-h2:text-[clamp(24px,3vw,32px)] prose-h2:leading-[1.2] prose-h2:mt-14 prose-h2:mb-5",
            "prose-h3:text-[clamp(18px,2vw,22px)] prose-h3:leading-[1.3] prose-h3:mt-10 prose-h3:mb-4",
            // Body text
            "prose-p:text-[17px] prose-p:font-light prose-p:leading-[1.75] prose-p:text-[#404040]",
            // Links
            "prose-a:text-accent prose-a:no-underline prose-a:border-b prose-a:border-transparent hover:prose-a:border-accent prose-a:transition-colors",
            // Strong
            "prose-strong:font-semibold prose-strong:text-dark",
            // Lists
            "prose-ul:list-none prose-ul:pl-0",
            "prose-li:text-[17px] prose-li:font-light prose-li:leading-[1.75] prose-li:text-[#404040] prose-li:pl-6 prose-li:relative",
            // Blockquote
            "prose-blockquote:border-l-[3px] prose-blockquote:border-accent prose-blockquote:pl-6 prose-blockquote:italic prose-blockquote:text-[#525252] prose-blockquote:not-italic prose-blockquote:font-light",
            // Code
            "prose-code:text-sm prose-code:bg-[#f5f5f5] prose-code:px-1.5 prose-code:py-0.5 prose-code:rounded prose-code:font-normal",
          ]}
        >
          <slot />
        </div>
      </Reveal>

      <!-- Back Link -->
      <Reveal client:load delay={0.15}>
        <div class="mt-12 md:mt-16 pt-8 border-t border-[#e5e5e5]">
          <a
            href="/blog"
            class="inline-flex items-center gap-2 text-sm sm:text-base font-medium text-dark hover:text-accent transition-colors duration-250"
          >
            ← Zurück zum Blog
          </a>
        </div>
      </Reveal>

      <!-- Author Box -->
      <Reveal client:load delay={0.2}>
        <div class="mt-10 p-6 md:p-8 bg-[#fafafa] border border-[#e5e5e5]">
          <div class="flex gap-5 items-start">
            <div
              class="w-14 h-14 rounded-full bg-[#e5e5e5] shrink-0 flex items-center justify-center overflow-hidden"
            >
              <img
                src="/signet-loschke-highlight.png"
                alt="Rico Loschke"
                class="w-full h-full object-cover"
                loading="lazy"
              />
            </div>
            <div>
              <h4 class="text-base font-black mb-1">Rico Loschke</h4>
              <p class="text-[13px] font-medium text-accent mb-3">
                AI Transformation Consultant
              </p>
              <p class="text-sm font-light leading-[1.6] text-[#525252]">
                Ich begleite Unternehmen auf dem Weg der KI-Transformation.
                Dabei verbinde ich technisches Know-how mit strategischem
                Denken.
              </p>
            </div>
          </div>
        </div>
      </Reveal>
    </div>
  </div>
</article>
