---
import { Reveal } from "@components/ui/Reveal";
import { Dot } from "@components/ui/Dot";

const hebel = [
  {
    num: "01",
    title: "Mitarbeitende",
    core: "Niemand kann für jemand anderen lernen.",
    body: "Der schnellste Hebel braucht keine Abstimmung, kein Budget, kein Projekt. Nur die Entscheidung, heute anzufangen. Voraussetzung: ein Rahmen, in dem diese Entscheidung möglich wird.",
  },
  {
    num: "02",
    title: "Team",
    core: "Die besten Ideen stecken in den täglichen Abläufen.",
    body: "Teams kennen ihre Probleme besser als jede Stabsstelle. Wenn einer im Team einen Weg findet, ziehen die anderen nach. Voraussetzung: Austausch, der systematisch stattfindet. Nicht zufällig auf dem Flur.",
  },
  {
    num: "03",
    title: "Organisation",
    core: "Führung setzt den Rahmen. Alles andere folgt daraus.",
    body: "Ohne Freiraum passiert nichts. Ohne klares Signal von oben bleiben gute Ansätze Einzelinitiativen. Dieser Hebel lässt sich nicht delegieren.",
  },
];

const phasen = [
  {
    num: "01",
    title: "Verstehen",
    core: "Bevor entschieden wird, muss sichtbar werden, was schon da ist.",
  },
  {
    num: "02",
    title: "Entscheiden",
    core: "Ohne Commitment der Führung bleibt jede Befähigung wirkungslos.",
  },
  {
    num: "03",
    title: "Aktivieren",
    core: "Menschen ändern sich, wenn sie den Vorteil selbst erkennen.",
  },
  {
    num: "04",
    title: "Verankern",
    core: "KI bleibt kein Projekt. Sie wird Teil der Arbeitskultur.",
  },
];
---

<section
  id="wie-ich-arbeite"
  class="py-16 md:py-24 lg:py-[100px] px-6 sm:px-10 md:px-16 lg:px-20 bg-[#fafafa] border-t border-[#e5e5e5]"
>
  <div
    class="grid grid-cols-1 md:grid-cols-[minmax(100px,240px)_1fr] gap-6 md:gap-12 lg:gap-15 items-start"
  >
    <Reveal client:load>
      <div class="md:sticky md:top-[98px]">
        <p
          class="text-xs sm:text-sm font-medium text-[#737373] tracking-[0.08em] uppercase mb-4"
        >
          Wie ich arbeite
        </p>
        <p
          class="text-sm font-light leading-[1.6] text-[#737373] max-w-[180px] hidden md:block"
        >
          Drei Hebel gleichzeitig. Vier Phasen nacheinander.
        </p>
      </div>
    </Reveal>

    <div class="max-w-full md:max-w-[700px]">
      <Reveal client:load>
        <h2
          class="text-3xl sm:text-4xl md:text-[clamp(34px,4.5vw,60px)] font-black leading-[0.95] tracking-[-0.025em] mb-5 md:mb-6"
        >
          Drei Hebel.<br />Vier Phasen<Dot />
        </h2>
      </Reveal>

      <Reveal client:load delay={0.06}>
        <p
          class="text-base sm:text-lg font-light leading-[1.75] text-[#525252] max-w-[560px] mb-12 md:mb-14"
        >
          Transformation passiert nicht an einem Ort und nicht linear. Sie
          braucht drei Hebel, die gleichzeitig ziehen. Und vier Phasen, die
          aufeinander aufbauen. Wer einen Hebel auslässt oder eine Phase
          überspringt, zahlt später doppelt.
        </p>
      </Reveal>

      {/* Drei Hebel */}
      <Reveal client:load delay={0.12}>
        <p class="text-xs font-medium text-accent uppercase tracking-[0.08em] mb-5 md:mb-6">
          Die drei Hebel · es geht nur gemeinsam
        </p>
      </Reveal>

      {
        hebel.map((h, i) => (
          <Reveal client:load delay={0.14 + i * 0.06}>
            <div class="py-7 md:py-8 border-t border-[#d4d4d4] last:border-b">
              <div class="flex gap-4 md:gap-6 items-baseline">
                <span class="text-2xl sm:text-3xl font-black tracking-[-0.02em] flex-shrink-0 w-12 md:w-14 text-accent">
                  {h.num}
                </span>
                <div class="flex-1 max-w-[600px]">
                  <h3 class="text-xl sm:text-2xl font-black tracking-[-0.015em] leading-[1.15] mb-2 text-dark">
                    {h.title}
                  </h3>
                  <p class="text-sm font-medium text-accent mb-3 tracking-[0.01em]">
                    {h.core}
                  </p>
                  <p class="text-base font-light leading-[1.7] text-[#525252]">
                    {h.body}
                  </p>
                </div>
              </div>
            </div>
          </Reveal>
        ))
      }

      {/* Vier Phasen */}
      <Reveal client:load delay={0.32}>
        <p class="mt-14 md:mt-16 text-xs font-medium text-accent uppercase tracking-[0.08em] mb-5 md:mb-6">
          Die vier Phasen · die Reihenfolge entscheidet
        </p>
      </Reveal>

      <div class="grid grid-cols-1 sm:grid-cols-2 gap-5 md:gap-6">
        {
          phasen.map((p, i) => (
            <Reveal client:load delay={0.36 + i * 0.05}>
              <div class="border-t border-[#d4d4d4] pt-5 md:pt-6 h-full">
                <div class="flex items-baseline gap-3 mb-2">
                  <span class="text-xl sm:text-2xl font-black tracking-[-0.02em] text-accent">
                    {p.num}
                  </span>
                  <h4 class="text-lg sm:text-xl font-black tracking-[-0.015em] leading-[1.15] text-dark">
                    {p.title}
                  </h4>
                </div>
                <p class="text-sm sm:text-[15px] font-light leading-[1.6] text-[#525252]">
                  {p.core}
                </p>
              </div>
            </Reveal>
          ))
        }
      </div>

      {/* build.jetzt + Schluss-Hinweis */}
      <Reveal client:load delay={0.56}>
        <div class="mt-14 md:mt-16 max-w-[600px]">
          <blockquote
            class="border-l-[3px] border-accent pl-6 py-1 font-serif text-xl md:text-2xl leading-[1.45] text-[#151416] mb-8"
          >
            Und ein Werkzeug, das die Zwischenzeit überbrückt.
          </blockquote>
          <p class="text-base sm:text-lg font-light leading-[1.75] text-[#525252] mb-6">
            Viele Unternehmen haben noch kein etabliertes KI-Ökosystem. Die
            Governance läuft, die IT prüft, die Mitarbeiter warten. In dieser
            Zwischenzeit bringe ich <strong class="text-dark">build.jetzt</strong>
            mit. Eine geschützte Plattform, auf der Teams sofort arbeiten
            können. Kein Risiko mit Produktivdaten, keine Compliance-Probleme.
          </p>
          <p class="text-base sm:text-lg font-light leading-[1.75] text-[#525252]">
            Wer es konkreter braucht: Das <strong class="text-dark">Chefsache
            Intensive</strong> ist zwei Tage Präsenz für Führungskräfte, die KI
            selbst verstehen wollen. Die <strong class="text-dark">Transformationsbegleitung</strong>
            startet mit einem Auftakt-Paket und wird danach gemeinsam weiter
            designt. Formate, Abläufe und Preise stehen auf
            <a
              href="https://unlearn.how/methode"
              target="_blank"
              rel="noopener"
              class="text-accent border-b border-transparent hover:border-accent transition-colors duration-250"
              >unlearn.how</a
            >.
          </p>
        </div>
      </Reveal>
    </div>
  </div>
</section>
