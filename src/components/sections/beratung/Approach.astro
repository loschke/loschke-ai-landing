---
import { Reveal } from "@components/ui/Reveal";
import { Dot } from "@components/ui/Dot";

const layers = [
  {
    num: "I",
    title: "Verstehen",
    core: "Führung muss KI selbst erleben",
    body: `Führungskräfte müssen KI selbst erleben. Nicht aus Berater-Slides, nicht aus Demos. Sondern selbst einen Prompt geschrieben, selbst die Grenzen gespürt haben. Zwei Tage reichen, um vom Beobachter zum Architekten zu werden. Das ist die Basis für alles Weitere.`,
  },
  {
    num: "II",
    title: "Befähigen",
    core: "Teams brauchen mehr als eine Schulung",
    body: `Ein einzelner Workshop verpufft, wenn der Boden nicht bereitet ist. Deshalb arbeite ich mit einer Abfolge von Impulsen über Wochen. Erst die Führungskraft, dann der Impuls für alle, dann die Team-Befähigung, dann die Reflexion. Jeder Schritt verschiebt die innere Bereitschaft ein Stück.`,
  },
  {
    num: "III",
    title: "Werkzeuge mitbringen",
    core: "Die Plattform-Lücke schließen",
    body: `Viele Unternehmen haben noch kein etabliertes KI-Ökosystem. Die Governance läuft, die IT prüft, die Mitarbeiter warten. In dieser Zwischenzeit bringe ich build.jetzt mit. Eine geschützte Plattform, auf der Teams sofort arbeiten können. Kein Risiko mit Produktivdaten, keine Compliance-Probleme. Konfigurierbar auf das Unternehmen.`,
  },
];
---

<section
  id="wie-ich-arbeite"
  class="py-16 md:py-24 lg:py-[100px] px-6 sm:px-10 md:px-16 lg:px-20 bg-[#fafafa] border-t border-[#e5e5e5]"
>
  <div
    class="grid grid-cols-1 md:grid-cols-[minmax(100px,240px)_1fr] gap-6 md:gap-12 lg:gap-15 items-start"
  >
    <Reveal client:load>
      <div class="md:sticky md:top-[98px]">
        <p
          class="text-xs sm:text-sm font-medium text-[#737373] tracking-[0.08em] uppercase mb-4"
        >
          Wie ich arbeite
        </p>
        <p
          class="text-sm font-light leading-[1.6] text-[#737373] max-w-[180px] hidden md:block"
        >
          Drei Ebenen, die sich verschränken. Keine drei Schubladen.
        </p>
      </div>
    </Reveal>

    <div class="max-w-full md:max-w-[700px]">
      <Reveal client:load>
        <h2
          class="text-3xl sm:text-4xl md:text-[clamp(34px,4.5vw,60px)] font-black leading-[0.95] tracking-[-0.025em] mb-5 md:mb-6"
        >
          Drei Ebenen<Dot />
        </h2>
      </Reveal>

      <Reveal client:load delay={0.06}>
        <p
          class="text-base sm:text-lg font-light leading-[1.75] text-[#525252] max-w-[560px] mb-10 md:mb-12"
        >
          Mein Angebot ist kein Baukastensystem mit drei Schubladen. Es sind
          drei Ebenen, die sich verschränken. Führungskräfte starten beim
          Verstehen, arbeiten in Workshops mit echten Werkzeugen und vertiefen
          eigenständig. Die Trennung ist modal, nicht exklusiv.
        </p>
      </Reveal>

      {
        layers.map((l, i) => (
          <Reveal client:load delay={0.1 + i * 0.06}>
            <div class="py-10 md:py-12 border-t border-[#d4d4d4] last:border-b">
              <div class="flex gap-4 md:gap-6 items-baseline">
                <span class="text-2xl sm:text-3xl md:text-4xl font-black tracking-[-0.02em] flex-shrink-0 w-12 md:w-16 text-accent">
                  {l.num}
                </span>
                <div class="flex-1 max-w-[600px]">
                  <h3 class="text-2xl sm:text-3xl md:text-[clamp(24px,3vw,32px)] font-black tracking-[-0.02em] leading-[1.1] mb-2 text-dark">
                    {l.title}
                  </h3>
                  <p class="text-sm font-medium text-accent mb-4 tracking-[0.01em]">
                    {l.core}
                  </p>
                  <p class="text-base sm:text-[17px] font-light leading-[1.7] text-[#525252]">
                    {l.body}
                  </p>
                </div>
              </div>
            </div>
          </Reveal>
        ))
      }

      <Reveal client:load delay={0.32}>
        <div class="mt-10 md:mt-14 max-w-[600px]">
          <blockquote
            class="border-l-[3px] border-accent pl-6 py-1 font-serif text-xl md:text-2xl leading-[1.45] text-[#151416] mb-8"
          >
            Dazu steht dauerhaft mein Lern-Angebot zur Verfügung. Hier kann
            jeder in seinem Tempo selbst vertiefen und ausprobieren.
          </blockquote>
          <p class="text-base sm:text-lg font-light leading-[1.75] text-[#525252]">
            Wer es konkreter braucht: Das <strong class="text-dark">Chefsache
            Intensive</strong> ist zwei Tage Präsenz für Führungskräfte, die KI
            selbst verstehen wollen. Die <strong class="text-dark">Transformationsbegleitung</strong>
            startet mit einem Auftakt-Paket und wird danach gemeinsam weiter
            designt. Formate, Abläufe und Preise stehen auf
            <a
              href="https://unlearn.how"
              target="_blank"
              rel="noopener"
              class="text-accent border-b border-transparent hover:border-accent transition-colors duration-250"
              >unlearn.how</a
            >.
          </p>
        </div>
      </Reveal>
    </div>
  </div>
</section>
