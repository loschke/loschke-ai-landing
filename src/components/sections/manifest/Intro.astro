---
import { Reveal } from "@components/ui/Reveal";
import { Dot } from "@components/ui/Dot";
---

<section
  class="py-16 md:py-24 lg:py-[100px] px-6 sm:px-10 md:px-16 lg:px-20 bg-[#fafafa]"
>
  <div
    class="grid grid-cols-1 md:grid-cols-[minmax(100px,240px)_1fr] gap-6 md:gap-12 lg:gap-15 items-start"
  >
    <!-- Left Label -->
    <Reveal client:load>
      <div class="md:sticky md:top-[98px]">
        <p
          class="text-xs sm:text-sm font-medium text-[#737373] tracking-[0.08em] uppercase mb-4"
        >
          Haltung
        </p>
        <p
          class="text-sm font-light leading-[1.6] text-[#737373] max-w-[180px] hidden md:block"
        >
          Die Grundlage meiner Arbeit mit Menschen und Technologie.
        </p>
      </div>
    </Reveal>

    <!-- Right Content -->
    <div class="max-w-full md:max-w-[680px]">
      <!-- Main Statement in Serif -->
      <Reveal client:load>
        <h2
          class="text-3xl sm:text-4xl md:text-[clamp(34px,4.5vw,60px)] font-black leading-[0.95] tracking-[-0.025em] mb-5 md:mb-7"
        >
          Ich glaube, das<br />geht anders<Dot />
        </h2>
      </Reveal>

      <!-- Serif Lead -->
      <Reveal client:load delay={0.08}>
        <p
          class="text-xl sm:text-2xl md:text-[clamp(22px,2.8vw,34px)] font-serif leading-[1.45] mb-5 md:mb-7"
        >
          Nicht mit mehr Hype. Nicht mit dem nächsten "Game-Changer". Sondern
          mit klarem Denken, ehrlicher Einschätzung und praktischer Umsetzung.
        </p>
      </Reveal>

      <!-- Body Text -->
      <Reveal client:load delay={0.12}>
        <p
          class="text-base sm:text-lg font-sans font-light leading-[1.75] text-[#525252] max-w-full md:max-w-[560px]"
        >
          Das hier sind die Grundsätze, nach denen ich arbeite – mit mir selbst
          und mit den Menschen, die ich begleite. Keine Marketing-Phrasen, keine
          Buzzwords. Sondern Überzeugungen, die sich in der Praxis bewährt
          haben.
        </p>
      </Reveal>
    </div>
  </div>
</section>
