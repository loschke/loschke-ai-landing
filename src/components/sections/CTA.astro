---
import { Reveal } from "@components/ui/Reveal";
import { Dot } from "@components/ui/Dot";

interface Props {
  headline?: string;
  text?: string;
}

const {
  headline = "Lass uns\nreden",
  text = "Du willst mich für eine Keynote buchen, hast eine Frage zu einem Artikel, oder willst einfach Hallo sagen? Schreib mir.",
} = Astro.props;

// Split headline by \n for line breaks
const headlineLines = headline.split("\n");
---

<section
  class="py-24 md:py-32 lg:py-[140px] px-6 sm:px-10 md:px-16 lg:px-20 bg-[#fafafa]"
>
  <Reveal client:load>
    <div
      class="grid grid-cols-1 md:grid-cols-[minmax(100px,240px)_1fr] gap-6 md:gap-12 lg:gap-15 items-start"
    >
      <div></div>
      <div class="max-w-full md:max-w-[700px]">
        <h2
          class="text-4xl sm:text-5xl md:text-[clamp(38px,5.5vw,76px)] font-black leading-[0.92] tracking-[-0.03em] mb-6 md:mb-7"
        >
          {
            headlineLines.map((line, i) => (
              <>
                {line}
                {i < headlineLines.length - 1 && <br />}
              </>
            ))
          }<Dot />
        </h2>
        <p
          class="text-base sm:text-lg font-light leading-[1.75] text-[#525252] max-w-full md:max-w-[440px] mb-8 md:mb-9"
        >
          {text}
        </p>
        <div class="flex flex-wrap gap-6 md:gap-7 items-center">
          <a
            href="/contact"
            class="inline-block bg-dark text-white px-7 py-3.5 text-sm font-medium tracking-wide transition-colors duration-300 hover:bg-accent"
          >
            Schreib mir
          </a>
          <a
            href="https://www.linkedin.com/in/rico-loschke/"
            target="_blank"
            rel="noopener"
            class="text-sm font-medium text-accent border-b border-transparent hover:border-accent transition-colors duration-250"
          >
            LinkedIn →
          </a>
        </div>
      </div>
    </div>
  </Reveal>
</section>
