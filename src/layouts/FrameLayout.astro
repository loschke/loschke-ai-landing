---
import "@/styles/global.css";
import "@fontsource/noto-sans";
import "@fontsource/noto-sans/900.css";
import "@fontsource/instrument-serif";
import SEO from "@components/SEO.astro";
import { Nav } from "@components/layout/Nav";
import Footer from "@components/Footer.astro";
import { ViewTransitions } from "astro:transitions";

interface Props {
  title: string;
  description: string;
  image?: string;
  article?: boolean;
}

const { title, description, image, article } = Astro.props;
---

<!doctype html>
<html lang="de">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <SEO
      title={title}
      description={description}
      image={image}
      article={article}
    />
    <ViewTransitions />
    {
      import.meta.env.PUBLIC_UMAMI_SCRIPT_URL &&
        import.meta.env.PUBLIC_UMAMI_WEBSITE_ID && (
          <script
            defer
            src={import.meta.env.PUBLIC_UMAMI_SCRIPT_URL}
            data-website-id={import.meta.env.PUBLIC_UMAMI_WEBSITE_ID}
          />
        )
    }
  </head>
  <body class="bg-white text-dark font-sans min-h-screen">
    <!-- Fixed Frame -->
    <div
      class="fixed inset-0 z-[9999] pointer-events-none border-[18px] border-accent box-border"
      transition:persist
    >
    </div>

    <!-- Scrollable Content Wrapper -->
    <div class="p-[18px]">
      <div class="bg-white min-h-[calc(100vh-36px)] relative">
        <Nav client:load transition:persist />
        <main transition:animate="fade">
          <slot />
        </main>
        <Footer />
      </div>
    </div>
  </body>
</html>
